generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  password        String
  name            String
  lastName        String
  createdEmployee Employee[]
}

model Employee {
  id             String    @id @default(uuid())
  firstName      String
  lastName       String
  surName        String?
  age            Int
  birthDate      DateTime?
  profession     String
  address        String
  employeeNumber String?
  height         Int?
  clothingSize   String?
  shoeSize       String?
  userId         String
  telegramChatId String?   @unique
  user           User      @relation(fields: [userId], references: [id])
}

model Inventory {
  id         String   @id @default(uuid())
  itemName   String
  itemType   String
  issueDate  DateTime @default(now())
  quantity   Int      @default(1)
  status     String   @default("выдан")
  employeeId String
  sizNormId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model InventoryAddon {
  id                  String   @id @default(uuid())
  name                String
  issueDate           DateTime @default(now())
  wearPeriodMonths    Int
  nextReplacementDate DateTime
  inventoryId         String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model SizNorm {
  id             String   @id @default(uuid())
  name           String
  classification String?
  quantity       Int      @default(1)
  period         String
  periodType     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TelegramSizRequest {
  id             String    @id @default(uuid())
  employeeId     String
  telegramChatId String
  sizNormId      String
  sizNormName    String
  quantity       Int       @default(1)
  issueDate      DateTime
  status         String    @default("pending")
  adminChatId    String?
  decidedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
